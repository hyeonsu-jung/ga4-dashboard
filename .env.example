# Google OAuth (Google Cloud Console → 사용자 인증 정보 → OAuth 2.0 클라이언트 ID)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth 콜백 URL (로컬: http://localhost:3000/api/auth/callback)
# Vercel 배포 시 미설정하면 자동으로 https://<도메인>/api/auth/callback 사용
GOOGLE_REDIRECT_URI=

# 세션 쿠키 서명용 비밀키 (임의의 긴 랜덤 문자열)
SESSION_SECRET=
