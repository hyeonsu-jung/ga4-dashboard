{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/*.js": { "maxDuration": 30 }
  },
  "redirects": [
    { "source": "/", "destination": "/index.html", "statusCode": 307 }
  ],
  "rewrites": [
    { "source": "/meta", "destination": "/meta.html" },
    { "source": "/ga4", "destination": "/index.html" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
